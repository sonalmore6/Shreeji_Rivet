# ─── Express + Nodemailer Configuration ──────────────────────────────────────
#
# Gmail SMTP — use an App Password (NOT your real Gmail password):
#   1. Go to myaccount.google.com → Security → 2-Step Verification (enable it)
#   2. Then go to myaccount.google.com → Security → App passwords
#   3. Create an app password for "Mail" → copy the 16-character code
#   4. Paste it as SMTP_PASS below (no spaces)
#
# SMTP_USER  → your Gmail address (e.g. sonalkmore06@gmail.com)
# SMTP_PASS  → 16-char App Password from step 3
# INQUIRY_TO → email that receives customer enquiries (usually same as SMTP_USER)
# PORT       → Express server port (default 3001)
# ─────────────────────────────────────────────────────────────────────────────

SMTP_USER=shreejirivetindia@gmail.com
SMTP_PASS=ibbf zlxp mcsy frah
INQUIRY_TO=shreejirivetindia@gmail.com
PORT=3001
